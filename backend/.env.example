# Database - Replace with your RDS endpoint after creating it
DATABASE_URL=postgresql://taskuser:taskpassword@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/taskmanager

# Secret key for JWT tokens - change this to something random
SECRET_KEY=change-this-to-a-random-string-in-production

# Frontend URL on CloudFront - replace after setting up CloudFront
ALLOWED_ORIGINS=https://your-cloudfront-id.cloudfront.net

# Port the app runs on
PORT=5000
